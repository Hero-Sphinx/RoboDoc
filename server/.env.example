# Copy this file to .env and fill in real values. Never commit the real .env.

# Postgres connection string (Neon: copy from your Neon project dashboard)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Google Gemini API key - https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Twilio credentials - https://console.twilio.com
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=+1XXXXXXXXXX
DOCTOR_PHONE=+1XXXXXXXXXX

# Long, random secret used to sign login JWTs (e.g. `openssl rand -hex 32`)
JWT_SECRET=

# Port the server listens on. Most hosts (Render, etc.) set this automatically -
# only needed for local overrides.
PORT=5000

# The deployed frontend's origin, used for CORS + Socket.io.
# Local dev default: http://localhost:5173
# Production example: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
