datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model TriageRecord {
  id        Int      @id @default(autoincrement())
  patient   String
  symptoms  String   @db.Text
  diagnosis String?  @db.Text
  urgency   String
  language  String   @default("English") 
  createdAt DateTime @default(now())
}